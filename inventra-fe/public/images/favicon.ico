<svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">

<defs>
  <linearGradient id="boxGradient" x1="0" y1="0" x2="1" y2="1">
    <stop offset="0%" stop-color="#465fff"/>
    <stop offset="100%" stop-color="#2a31d8"/>
  </linearGradient>

  <linearGradient id="checkGradient" x1="0" y1="0" x2="1" y2="1">
    <stop offset="0%" stop-color="#34d399"/>
    <stop offset="100%" stop-color="#22c55e"/>
  </linearGradient>
</defs>

<!-- Box -->
<rect x="10" y="22" width="44" height="34" rx="6" fill="url(#boxGradient)"/>

<!-- Lid -->
<polygon points="10,22 22,12 54,12 42,22" fill="#7592ff"/>

<!-- Check -->
<path d="M20 36 L30 46 L46 28" stroke="url(#checkGradient)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>

</svg>